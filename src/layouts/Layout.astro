---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jiu Jitsu Meadowbrook | Rob Williams BJJ – South Brisbane & Logan',
  description = 'Authentic Gracie Jiu Jitsu self-defence academy in Meadowbrook, South Brisbane. Classes for kids, teens and adults in the Logan area. Book your free trial today.',
} = Astro.props;

const siteBase   = 'https://www.robwilliamsbjj.com';
const canonicalURL = new URL(Astro.url.pathname, siteBase).href;
const ogImage    = `${siteBase}/hero-bg.jpg`;
---

<!doctype html>
<html lang="en" style="scroll-behavior: smooth;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name"   content="Rob Williams BJJ" />

    <!-- Local Business structured data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SportsClub",
        "name": "Rob Williams BJJ",
        "description": "Authentic Gracie Jiu Jitsu self-defence academy in Meadowbrook, South Brisbane, serving the Logan area.",
        "url": "https://www.robwilliamsbjj.com",
        "image": "https://www.robwilliamsbjj.com/hero-bg.jpg",
        "priceRange": "$$",
        "telephone": "+61421729868",
        "email": "robwilliamsgz@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "3/45 Nealdon Dr",
          "addressLocality": "Meadowbrook",
          "addressRegion": "QLD",
          "postalCode": "4131",
          "addressCountry": "AU"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -27.6833,
          "longitude": 153.0833
        },
        "openingHoursSpecification": [
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Monday",    "opens": "10:00", "closes": "20:00" },
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday",   "opens": "17:00", "closes": "20:00" },
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Wednesday", "opens": "10:00", "closes": "11:00" },
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday",  "opens": "17:00", "closes": "20:00" },
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday",    "opens": "10:00", "closes": "11:00" },
          { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday",  "opens": "08:00", "closes": "10:30" }
        ],
        "hasMap": "https://maps.google.com/?q=3/45+Nealdon+Dr+Meadowbrook+QLD+4131",
        "sameAs": [
          "https://www.instagram.com/rwbjj_meadowbrook_/",
          "https://www.facebook.com/robwilliamsbjj",
          "https://www.youtube.com/@robwilliamsbjj8446"
        ]
      }
    </script>

    <title>{title}</title>

    <style is:global>
      /* Shared inner-page hero — consistent crop & size across all pages */
      .page-hero {
        background: linear-gradient(to bottom, rgba(13,13,13,0.45) 0%, rgba(13,13,13,0.88) 85%, #1a1a1a 100%),
                    url('/hero-bg.jpg') center 55% / cover no-repeat;
        min-height: 48vw;
        position: relative;
        overflow: hidden;
      }
      @media (min-width: 768px) {
        .page-hero {
          background-position: center 45%;
          min-height: 70vh;
        }
      }

      /* Fade-in for hero content */
      @keyframes heroFadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .page-hero > div {
        animation: heroFadeUp 0.75s ease-out both;
      }

      /* Close the gap between hero and first content section */
      .page-hero + section {
        padding-top: 2rem;
      }
      @media (min-width: 768px) {
        .page-hero + section {
          padding-top: 3.5rem;
        }
      }

      /* Fade out bottom — hard/fast on mobile, long and smooth on desktop */
      .page-hero::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: linear-gradient(to bottom, transparent 0%, rgba(26,26,26,0.6) 45%, #1a1a1a 100%);
        pointer-events: none;
      }
      @media (min-width: 768px) {
        .page-hero::after {
          height: 120px;
          background: linear-gradient(to bottom, transparent, #1a1a1a);
        }
      }
    </style>
  </head>
  <body class="bg-brand-dark text-white font-body antialiased">
    <slot />

    <!-- ── NEW CLASS POPUP ─────────────────────────────────────── -->
    <div id="taipans-popup" class="hidden fixed inset-0 z-[100] flex items-center justify-center px-4" style="background:rgba(0,0,0,0.85);">
      <div class="relative max-w-sm w-full rounded-2xl overflow-hidden shadow-2xl" style="background: linear-gradient(135deg, #1a1a1a 0%, #2d1010 50%, #1a1a1a 100%);">
        <!-- Top accent bar -->
        <div style="height:5px; background: linear-gradient(90deg, #f59e0b, #d97706, #f59e0b);"></div>

        <div class="p-8 text-center">
          <button id="taipans-close" class="absolute top-4 right-4 text-white/40 hover:text-white text-xl leading-none transition">✕</button>

          <p class="uppercase tracking-widest text-xs font-bold mb-4" style="color:#f59e0b;">⚡ New Class Opening ⚡</p>
          <h2 class="font-display font-bold mb-1" style="font-size:2.8rem; line-height:1; color:#ffffff;">TAIPANS</h2>
          <p class="font-bold text-lg mb-5" style="color:#f59e0b;">Ages 12–15</p>

          <p class="text-white/80 text-sm leading-relaxed mb-6">
            Kick, punch, throw and grapple — in a controlled and progressive self defence system.
          </p>

          <div class="rounded-xl px-5 py-4 mb-6" style="background:rgba(255,255,255,0.06); border: 1px solid rgba(245,158,11,0.5);">
            <p class="font-bold text-white text-base">Wednesdays &amp; Fridays</p>
            <p class="text-white/60 text-sm mt-1">Next class: <span id="taipans-next-class-popup" class="font-bold text-white">Wednesday at 5:45pm</span></p>
          </div>

          <a href="/programs#taipans" class="block font-bold px-6 py-3 rounded-lg transition mb-3" style="background: linear-gradient(90deg, #f59e0b, #d97706); color:#111;">
            Book Now →
          </a>
          <button id="taipans-dismiss" class="text-white/30 hover:text-white/60 text-xs transition">Don't show again</button>
        </div>
      </div>
    </div>

    <script>
      (function () {
        // Compute the next Taipans class (Wed or Fri, 5:45pm) from today
        function nextTaipansClass(): string {
          const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
          const now = new Date();
          for (let i = 0; i < 8; i++) {
            const d = new Date(now);
            d.setDate(now.getDate() + i);
            const isClassDay = d.getDay() === 3 || d.getDay() === 5; // Wed or Fri
            if (!isClassDay) continue;
            const classTime = new Date(d);
            classTime.setHours(17, 45, 0, 0);
            if (classTime <= now) continue;
            return i === 0 ? `Today at 5:45pm` : i === 1 ? `Tomorrow at 5:45pm` : `${days[d.getDay()]} at 5:45pm`;
          }
          return 'Wednesday at 5:45pm';
        }
        document.querySelectorAll('#taipans-next-class-popup, #taipans-next-class-banner').forEach(el => {
          el.textContent = nextTaipansClass();
        });
      })();
    </script>

    <script>
      (function () {
        // Hide permanently after August 1 2026 AEST (UTC+10 = July 31 14:00 UTC)
        const expiry = new Date('2026-08-01T00:00:00+10:00');
        if (new Date() >= expiry) return;

        // Only show on homepage
        if (window.location.pathname !== '/') return;

        // Don't show if user dismissed
        if (localStorage.getItem('taipans-dismissed')) return;

        const popup = document.getElementById('taipans-popup');
        if (!popup) return;

        // Show after short delay
        setTimeout(() => popup.classList.replace('hidden', 'flex'), 800);

        function close() {
          popup.classList.replace('flex', 'hidden');
        }

        document.getElementById('taipans-close')?.addEventListener('click', close);
        popup.addEventListener('click', (e) => { if (e.target === popup) close(); });

        document.getElementById('taipans-dismiss')?.addEventListener('click', () => {
          localStorage.setItem('taipans-dismissed', '1');
          close();
        });
      })();
    </script>
  </body>
</html>
