---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const programs = [
  {
    name: 'Pythons',
    age: 'Ages 4–7',
    icon: '🦎',
    color: 'text-green-400',
    image: '/Pythons.jpg',
    imageAlt: 'Rob Williams coaching the Pythons kids class',
    desc: 'Fun, safe introduction to grappling. Builds coordination, confidence and essential life skills through age-appropriate games and movement.',
    details: [
      'Fundamental takedowns, throws and self-defence techniques',
      'Positional control and escape methods',
      'Anti-bullying strategies, empathy and leadership',
      'Self-discipline, teamwork and socialisation',
      'Improves fitness and coordination in a safe environment',
    ],
    booking: 'Booking essential — pre-book via ClubWorx',
    bookingLink: 'https://app.clubworx.com/websites/rob-williams-bjj/calendar/weekly_agenda',
    schedule: 'Tuesday & Thursday 5:00pm · 30 minute sessions',
  },
  {
    name: 'Anacondas',
    age: 'Ages 8–12',
    icon: '🐍',
    color: 'text-blue-400',
    image: '/Anacondas.jpg',
    imageAlt: 'Anacondas kids class',
    desc: 'Structured classes covering defence fundamentals, ground grappling and throws in a fun, challenging environment. Builds real technique and character.',
    details: [
      'Takedowns, throws, escapes and transitions',
      'Submissions including chokes and armlocks',
      'Anti-bullying, leadership and cooperation skills',
      'Team-building exercises and responsibility',
      'Friendly competitions for advanced students',
    ],
    booking: 'Booking essential — pre-book via ClubWorx',
    bookingLink: 'https://app.clubworx.com/websites/rob-williams-bjj/calendar/weekly_agenda',
    schedule: 'Tuesday 5:45pm · Thursday 5:45pm · Saturday 9:30am',
  },
  {
    name: 'Taipans',
    age: 'Ages 12–15',
    icon: '🐉',
    color: 'text-yellow-400',
    image: '/Gallery/Taipans1.JPG',
    imageAlt: 'Taipans class at Rob Williams BJJ',
    desc: 'Real Jiu Jitsu & self-defence. The perfect cross-training for any contact sport — and a great way to build real confidence for teens.',
    details: [
      'Real self-defence skills in a structured environment',
      'Takedowns, throws, escapes and ground control',
      'Builds discipline, focus and confidence',
      'Great cross-training for footy, rugby and other contact sports',
    ],
    booking: 'Booking essential — pre-book via ClubWorx',
    bookingLink: 'https://app.clubworx.com/websites/rob-williams-bjj/calendar/weekly_agenda',
    schedule: 'Wednesday & Friday 5:45pm',
    badge: 'First Class July 22nd',
    badgeExpiry: '2026-07-22T00:00:00+10:00',
    ctaSwitchDate: '2026-07-16T00:00:00+10:00',
  },
  {
    name: 'Women (13+)',
    id: 'women',
    age: '13 & Over',
    icon: '💪',
    color: 'text-pink-400',
    image: '/Womens.jpg',
    imageAlt: 'Women\'s class at Rob Williams BJJ',
    imgClass: 'scale-[1.15] [object-position:55%_50%] md:scale-[1.4] md:-translate-y-[15%] md:[object-position:75%_60%]',
    desc: 'A supportive, non-competitive environment to learn Jiu Jitsu at your own pace. No prior experience needed — just show up. Bring a friend.',
    details: [
      'Crawl, walk, run philosophy — no pressure, no comparisons',
      'Practical self-defence skills in a safe space',
      'Personalised progression at your own pace',
      'Encouraging community',
      'Booking essential — pre-book via ClubWorx',
    ],
    booking: 'Booking essential — pre-book via ClubWorx',
    bookingLink: 'https://app.clubworx.com/websites/rob-williams-bjj/calendar/weekly_agenda',
    schedule: 'Mondays 5:00pm',
  },
  {
    name: 'Adults',
    age: '16 & Over',
    icon: '🥋',
    color: 'text-brand-red',
    image: '/Adults.jpg',
    imageAlt: 'Adults class at Rob Williams BJJ',
    desc: 'Full Gracie Jiu Jitsu curriculum for beginners and experienced grapplers alike. Every class covers standing and ground techniques, drilling and live training.',
    details: [
      '2–3 techniques per class covering standing and ground work',
      'Gentle warm up, partner drilling, then free training or sparring',
      'Full Gracie Jiu Jitsu curriculum including weapons defence',
      'Suitable for complete beginners through to experienced grapplers',
      'Builds mutual respect and a strong training community',
    ],
    booking: 'Walk-in welcome',
    bookingLink: 'https://app.clubworx.com/websites/rob-williams-bjj/waivers/waiver-without-payment-auth/signed_waivers/new',
    schedule: 'Mon 10am & 6pm · Tue 6:30pm · Wed 10am · Thu 6:30pm · Fri 10am · Sat 8am',
  },
];
---

<Layout
  title="Programs | Rob Williams BJJ – South Brisbane"
  description="Jiu Jitsu classes for all ages in Meadowbrook, South Brisbane. Pythons (4–7), Anacondas (8–12), Women's classes and Adults — taught by Professor Rob Williams."
>
  <Header />

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="page-hero relative flex items-end px-6 pb-16 pt-32">
    <div class="max-w-5xl mx-auto w-full">
      <p class="text-brand-red uppercase tracking-widest text-sm font-semibold mb-3">What We Offer</p>
      <h1 class="font-display text-5xl md:text-6xl font-bold leading-tight">Our Programs</h1>
      <p class="text-white text-xl mt-4 font-semibold">Classes for every age and ability.</p>
    </div>
  </section>

  <!-- ─── PROGRAMS ─────────────────────────────────────────────── -->
  {programs.map((p, i) => (
    <>
      {i > 0 && (
        <div style={i % 2 === 0 ? "height:50px;background:linear-gradient(to bottom,#0d0d0d,#1a1a1a);" : "height:50px;background:linear-gradient(to bottom,#1a1a1a,#0d0d0d);"}></div>
      )}
    <section id={p.id ?? p.name.toLowerCase()} class={`py-24 px-6 scroll-mt-20 ${i % 2 === 0 ? 'bg-brand-gray' : 'bg-brand-dark'}`}>
      <div class="max-w-5xl mx-auto">
        <div class={`grid md:grid-cols-2 gap-16 items-center ${i % 2 === 1 ? 'md:[direction:rtl]' : ''}`}>

          <!-- Image -->
          <div class="md:[direction:ltr] rounded-2xl overflow-hidden h-[300px] md:h-[420px]">
            {p.image ? (
              <img
                src={p.image}
                alt={p.imageAlt}
                class={`w-full h-full object-cover ${p.imgClass ?? ''}`}
              />
            ) : (
              <div class="w-full h-full bg-brand-dark border border-white/10 flex flex-col items-center justify-center gap-3">
                <span class="text-5xl opacity-30">📸</span>
                <p class="text-white/30 text-sm font-medium uppercase tracking-widest">Photos Coming Soon</p>
              </div>
            )}
          </div>

          <!-- Content -->
          <div class="md:[direction:ltr]">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-3xl">{p.icon}</span>
              <p class="text-brand-red uppercase tracking-widest text-sm font-semibold">{p.age}</p>
            </div>
            <div class="flex items-center gap-3 mb-4 flex-wrap">
              <h2 class="font-display text-4xl font-bold">{p.name}</h2>
              {p.badge && (
                <span
                  id={`badge-${i}`}
                  class="hidden text-xs font-bold uppercase tracking-wide px-3 py-1 rounded-full"
                  style="background:rgba(245,158,11,0.15); color:#f59e0b; border:1px solid rgba(245,158,11,0.4);"
                  data-expiry={p.badgeExpiry}
                >
                  {p.badge}
                </span>
              )}
            </div>
            <p class="text-white/70 text-lg leading-relaxed mb-6">{p.desc}</p>

            <!-- Details list -->
            <ul class="space-y-2 mb-6">
              {p.details.map(d => (
                <li class="flex items-start gap-2">
                  <span class="text-brand-red shrink-0 mt-0.5">▸</span>
                  <span class="text-white/70 text-sm">{d}</span>
                </li>
              ))}
            </ul>

            <!-- Schedule -->
            <div class="bg-brand-dark/60 border border-white/10 rounded-xl px-5 py-4 mb-6">
              <p class="text-white/40 text-xs uppercase tracking-wide mb-1">Schedule</p>
              <p class="text-white/80 text-sm font-medium">{p.schedule}</p>
            </div>

            <!-- CTAs -->
            {p.ctaSwitchDate ? (
              <>
                <div id={`cta-comingsoon-${i}`} class="hidden">
                  <a
                    href="/contact"
                    class="text-center inline-block bg-brand-red hover:bg-red-700 text-white font-bold px-8 py-3 rounded-lg transition text-sm"
                  >
                    Contact Us for More Info →
                  </a>
                </div>
                <div id={`cta-real-${i}`} class="hidden flex-col sm:flex-row gap-3" data-switch={p.ctaSwitchDate}>
                  <a
                    href="https://app.clubworx.com/websites/rob-williams-bjj/waivers/waiver-without-payment-auth/signed_waivers/new" target="_blank" rel="noopener"
                    class="text-center bg-brand-red hover:bg-red-700 text-white font-bold px-8 py-3 rounded-lg transition text-sm"
                  >
                    Book a Free Trial
                  </a>
                  <a
                    href={p.bookingLink}
                    target={p.bookingLink.startsWith('http') ? '_blank' : undefined}
                    rel={p.bookingLink.startsWith('http') ? 'noopener' : undefined}
                    class="text-center border border-white/30 hover:border-white text-white font-semibold px-8 py-3 rounded-lg transition text-sm"
                  >
                    {p.booking}
                  </a>
                </div>
              </>
            ) : (
              <div class="flex flex-col sm:flex-row gap-3">
                <a
                  href="https://app.clubworx.com/websites/rob-williams-bjj/waivers/waiver-without-payment-auth/signed_waivers/new" target="_blank" rel="noopener"
                  class="text-center bg-brand-red hover:bg-red-700 text-white font-bold px-8 py-3 rounded-lg transition text-sm"
                >
                  Book a Free Trial
                </a>
                <a
                  href={p.bookingLink}
                  target={p.bookingLink.startsWith('http') ? '_blank' : undefined}
                  rel={p.bookingLink.startsWith('http') ? 'noopener' : undefined}
                  class="text-center border border-white/30 hover:border-white text-white font-semibold px-8 py-3 rounded-lg transition text-sm"
                >
                  {p.booking}
                </a>
              </div>
            )}
          </div>

        </div>
      </div>
    </section>
    </>
  ))}

  <script>
    (function () {
      const now = new Date();

      // Badges — hide once past their expiry date
      document.querySelectorAll<HTMLElement>('[id^="badge-"]').forEach(badge => {
        const expiry = badge.dataset.expiry;
        if (expiry && now < new Date(expiry)) {
          badge.classList.replace('hidden', 'inline-block');
        }
      });

      // CTA switch — show "coming soon" contact button before the switch date, real buttons after
      document.querySelectorAll<HTMLElement>('[id^="cta-real-"]').forEach(realCta => {
        const idx = realCta.id.replace('cta-real-', '');
        const comingSoon = document.getElementById(`cta-comingsoon-${idx}`);
        const switchDate = realCta.dataset.switch;
        if (!switchDate) return;

        if (now >= new Date(switchDate)) {
          realCta.classList.replace('hidden', 'flex');
        } else if (comingSoon) {
          comingSoon.classList.replace('hidden', 'block');
        }
      });
    })();
  </script>

  <!-- ─── AUTO-SCROLL PHOTO STRIP ─────────────────────────────── -->
  <div id="strip-programs" class="relative overflow-hidden h-52 md:h-72 bg-brand-dark">
    <div id="strip-programs-track" class="flex h-full">
      {[
        { src: '/Gallery/Adults.bluebelts.png',    alt: 'Blue belts training' },
        { src: '/Gallery/Kids.w.Rob.shaka.png',    alt: 'Kids with Rob' },
        { src: '/Gallery/Ladies.defendingback.png',alt: 'Ladies defending back' },
        { src: '/Gallery/Adults.nogi.png',         alt: 'No-Gi class' },
        { src: '/Gallery/Kids.climbingtrees.png',  alt: 'Kids having fun' },
        { src: '/Gallery/Adults.passing.png',      alt: 'Guard passing' },
        { src: '/Gallery/Ladies.RNC.png',          alt: 'Ladies RNC defence' },
        { src: '/Gallery/Adults.hittingpads.png',  alt: 'Striking pads' },
        { src: '/Gallery/Kids.strech.png',         alt: 'Kids stretching' },
        { src: '/Gallery/Adults.shaka.png',        alt: 'Adults shaka' },
        { src: '/Gallery/Adults.bluebelts.png',    alt: 'Blue belts training' },
        { src: '/Gallery/Kids.w.Rob.shaka.png',    alt: 'Kids with Rob' },
        { src: '/Gallery/Ladies.defendingback.png',alt: 'Ladies defending back' },
        { src: '/Gallery/Adults.nogi.png',         alt: 'No-Gi class' },
        { src: '/Gallery/Kids.climbingtrees.png',  alt: 'Kids having fun' },
        { src: '/Gallery/Adults.passing.png',      alt: 'Guard passing' },
        { src: '/Gallery/Ladies.RNC.png',          alt: 'Ladies RNC defence' },
        { src: '/Gallery/Adults.hittingpads.png',  alt: 'Striking pads' },
        { src: '/Gallery/Kids.strech.png',         alt: 'Kids stretching' },
        { src: '/Gallery/Adults.shaka.png',        alt: 'Adults shaka' },
      ].map(({ src, alt }) => (
        <img src={src} alt={alt} loading="lazy" class="h-full w-auto flex-shrink-0 object-cover" />
      ))}
    </div>
    <button id="strip-programs-prev" class="strip-nav-btn absolute left-3 top-1/2 -translate-y-1/2 z-10">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button id="strip-programs-next" class="strip-nav-btn absolute right-3 top-1/2 -translate-y-1/2 z-10">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
    </button>
  </div>

  <style>
    .strip-nav-btn {
      background: rgba(0,0,0,0.55);
      border: 1px solid rgba(255,255,255,0.2);
      color: white;
      border-radius: 50%;
      width: 2.25rem;
      height: 2.25rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s, border-color 0.2s;
    }
    .strip-nav-btn:hover { background: #c41230; border-color: #c41230; }
  </style>

  <script>
    (function() {
      const track = document.getElementById('strip-programs-track') as HTMLElement;
      const prev  = document.getElementById('strip-programs-prev')  as HTMLElement;
      const next  = document.getElementById('strip-programs-next')  as HTMLElement;
      if (!track) return;

      let pos      = 0;
      let paused   = false;
      let lastTime = performance.now();
      const jump     = 400;
      const duration = 80000;

      function half() { return track.scrollWidth / 2; }

      function tick(now: number) {
        const dt = now - lastTime;
        lastTime = now;
        if (!paused) {
          pos += (half() / duration) * dt;
          if (pos >= half()) pos -= half();
        }
        track.style.transform = `translateX(-${pos}px)`;
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);

      track.addEventListener('mouseenter', () => paused = true);
      track.addEventListener('mouseleave', () => paused = false);

      prev?.addEventListener('click', () => {
        pos -= jump;
        if (pos < 0) pos += half();
      });
      next?.addEventListener('click', () => {
        pos += jump;
        if (pos >= half()) pos -= half();
      });
    })();
  </script>

  <!-- ─── COACHES ─────────────────────────────────────────────── -->
  <section class="py-16 px-6 bg-brand-dark border-t border-white/10">
    <div class="max-w-5xl mx-auto">
      <p class="text-center text-white/40 text-xs uppercase tracking-widest mb-6">Your Coaches</p>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href="/team#rob" class="group flex items-center gap-4 bg-brand-gray border border-white/10 hover:border-brand-red rounded-2xl p-4 transition">
          <img src="/KidsCoach_Rob.jpg" alt="Professor Rob Williams" class="w-16 h-16 rounded-xl object-cover object-top shrink-0" />
          <div class="flex-1 min-w-0">
            <p class="font-bold text-white text-sm">Professor Rob Williams</p>
            <p class="text-brand-red text-xs font-semibold mb-1">Head Coach</p>
            <p class="text-white/50 text-xs leading-relaxed">3rd Degree Black Belt · 7× NZ National Champion · PSBJJA Kids Coach</p>
          </div>
          <span class="text-white/20 group-hover:text-brand-red text-xs shrink-0 transition">View →</span>
        </a>
        <a href="/team#rane" class="group flex items-center gap-4 bg-brand-gray border border-white/10 hover:border-brand-red rounded-2xl p-4 transition">
          <img src="/KidsCoach_Rane.jpg" alt="Rane Labrum" class="w-16 h-16 rounded-xl object-cover object-top shrink-0" />
          <div class="flex-1 min-w-0">
            <p class="font-bold text-white text-sm">Rane Labrum</p>
            <p class="text-brand-red text-xs font-semibold mb-1">Assistant Coach</p>
            <p class="text-white/50 text-xs leading-relaxed">Blue Belt · Jiu Jitsu Champion · PSBJJA Qualified Kids Coach</p>
          </div>
          <span class="text-white/20 group-hover:text-brand-red text-xs shrink-0 transition">View →</span>
        </a>
      </div>
    </div>
  </section>

  <div style="height:50px;background:linear-gradient(to bottom,#0d0d0d,#1a1a1a);"></div>

  <!-- ─── CTA ─────────────────────────────────────────────────── -->
  <section class="py-20 px-6 bg-brand-gray text-center">
    <p class="text-brand-red uppercase tracking-widest text-sm font-semibold mb-3">Not Sure Where to Start?</p>
    <h2 class="font-display text-4xl font-bold mb-4">Your First 10 Days Are Free</h2>
    <p class="text-white/60 text-lg mb-10 max-w-lg mx-auto">
      Unlimited classes for 10 days at no cost. Meet Rob and the team, see the gym, and find out which program suits you best.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="https://app.clubworx.com/websites/rob-williams-bjj/waivers/waiver-without-payment-auth/signed_waivers/new" target="_blank" rel="noopener" class="bg-brand-red hover:bg-red-700 text-white font-bold text-lg px-10 py-4 rounded transition inline-block">
        Book a Free Trial
      </a>
      <a href="/timetable" class="border border-white/30 hover:border-white text-white font-semibold text-lg px-10 py-4 rounded transition inline-block">
        View Timetable & Pricing
      </a>
    </div>
  </section>

  <div style="height:50px;background:linear-gradient(to bottom,#1a1a1a,#0d0d0d);"></div>

  <!-- ─── FOOTER ────────────────────────────────────────────────── -->
  <footer class="bg-brand-dark py-14 px-6">
    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-10">
      <div>
        <p class="font-display text-xl font-bold mb-3">ROB WILLIAMS <span class="text-brand-red">BJJ</span></p>
        <p class="text-white/50 text-sm leading-relaxed">
          Authentic Gracie Jiu Jitsu self-defence academy.<br />
          South Brisbane · Meadowbrook QLD
        </p>
      </div>
      <div>
        <p class="font-semibold text-white/80 mb-4 text-sm uppercase tracking-wide">Contact</p>
        <ul class="space-y-3 text-white/60 text-sm">
          <li><a href="tel:0421729868" class="hover:text-white transition">📞 0421 729 868</a></li>
          <li><a href="mailto:robwilliamsgz@gmail.com" class="hover:text-white transition">✉️ robwilliamsgz@gmail.com</a></li>
          <li>
            <a href="https://www.google.com/maps/dir/?api=1&destination=3%2F45+Nealdon+Dr+Meadowbrook+QLD+4131" target="_blank" rel="noopener" class="hover:text-white transition">
              📍 3/45 Nealdon Dr, Meadowbrook QLD 4131
            </a>
          </li>
        </ul>
      </div>
      <div>
        <p class="font-semibold text-white/80 mb-4 text-sm uppercase tracking-wide">Quick Links</p>
        <ul class="space-y-2 text-white/60 text-sm">
          <li><a href="/about" class="hover:text-white transition">About</a></li>
          <li><a href="/programs" class="hover:text-white transition">Programs</a></li>
          <li><a href="/timetable" class="hover:text-white transition">Timetable &amp; Pricing</a></li>
          <li><a href="/team" class="hover:text-white transition">Our Team</a></li>
          <li><a href="/contact" class="hover:text-white transition">Contact</a></li>
          <li><a href="/faq" class="hover:text-white transition">FAQ</a></li>
          <li><a href="/resources" class="hover:text-white transition">Resources</a></li>
          <li><a href="https://app.clubworx.com/websites/rob-williams-bjj/waivers/waiver-without-payment-auth/signed_waivers/new" target="_blank" rel="noopener" class="hover:text-white transition">Free Trial</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-5xl mx-auto mt-10 pt-6 border-t border-white/10 text-center text-white/30 text-xs">
      © {new Date().getFullYear()} Rob Williams BJJ. All rights reserved.
    </div>
  </footer>

</Layout>
