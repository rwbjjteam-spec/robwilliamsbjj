---

<Layout
  title="Resources | Rob Williams BJJ – South Brisbane"
  description="Training resources for Rob Williams BJJ students. Watch the latest technique videos and explore the White-to-Blue Belt curriculum series."
>

  <Header />

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="page-hero relative flex items-end px-6 pb-16 pt-32">
    <div class="max-w-5xl mx-auto w-full">
      <p class="text-brand-red uppercase tracking-widest text-sm font-semibold mb-3">For Students</p>
      <h1 class="font-display text-5xl md:text-6xl font-bold leading-tight">
        Resources
      </h1>
      <p class="text-white/60 text-lg mt-4 max-w-xl">
        Technique videos, curriculum guides, and training materials — all in one place.
      </p>
    </div>
  </section>

  <!-- ─── LATEST VIDEO ─────────────────────────────────────────── -->
  <section class="py-24 px-6 bg-brand-gray">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-10">
        <p class="text-brand-red uppercase tracking-widest text-sm font-semibold mb-3">YouTube</p>
        <h2 class="font-display text-4xl font-bold">Basics of Jiu Jitsu</h2>
      </div>

      <div class="grid lg:grid-cols-[1fr_340px] gap-6 items-start">

        <div>
          <!-- Video embed -->
          <div class="relative w-full rounded-2xl overflow-hidden bg-black" style="aspect-ratio: 16/9;">
            <iframe
              id="latest-video-iframe"
              src={`https://www.youtube.com/embed/${latestVideoId}?rel=0&modestbranding=1`}
              title={latestVideoTitle}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="absolute inset-0 w-full h-full"
            ></iframe>
          </div>

          <!-- Video meta + channel link -->
          <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-6">
            <p class="text-white/60 text-sm">
              <span id="latest-video-title" class="text-white font-semibold">{latestVideoTitle}</span>
              &nbsp;·&nbsp; Rob Williams BJJ
            </p>
            <a
              href="https://www.youtube.com/@robwilliamsbjj8446"
              target="_blank"
              rel="noopener"
              class="shrink-0 border border-white/30 hover:border-white text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition"
            >
              View Full Channel →
            </a>
          </div>
        </div>

        <!-- Up Next list -->
        {upNextVideos.length > 0 && (
          <div class="bg-brand-dark border border-white/10 rounded-2xl p-4 lg:max-h-[420px] lg:overflow-y-auto">
            <p class="text-white/40 uppercase tracking-widest text-xs font-semibold mb-3 px-1">Up Next</p>
            <div class="space-y-2">
              {upNextVideos.map(v => (
                <button
                  class="playlist-item w-full flex items-center gap-3 text-left rounded-xl p-2 hover:bg-white/5 transition"
                  data-video-id={v.id}
                  data-video-title={v.title}
                >
                  <span class="relative shrink-0 w-24 h-14 rounded-lg overflow-hidden bg-black">
                    <img src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`} alt={v.title} class="w-full h-full object-cover" loading="lazy" />
                    <span class="absolute inset-0 flex items-center justify-center bg-black/20">
                      <span class="text-white text-lg">▶</span>
                    </span>
                  </span>
                  <span class="text-white/80 text-sm leading-snug line-clamp-2">{v.title}</span>
                </button>
              ))}
            </div>
          </div>
        )}

      </div>
    </div>
  </section>

  <script>
    (function () {
      const iframe = document.getElementById('latest-video-iframe') as HTMLIFrameElement | null;
      const titleEl = document.getElementById('latest-video-title');
      document.querySelectorAll<HTMLElement>('.playlist-item').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.videoId!;
          const title = btn.dataset.videoTitle!;
          if (iframe) iframe.src = `https://www.youtube.com/embed/${id}?rel=0&modestbranding=1&autoplay=1`;
          if (titleEl) titleEl.textContent = title;
          window.scrollTo({ top: (iframe?.closest('section') as HTMLElement)?.offsetTop ?? 0, behavior: 'smooth' });
        });
      });
    })();
  </script>


  <div style="height:50px;background:linear-gradient(to bottom,#1a1a1a,#0d0d0d);"></div>

  <!-- ─── CURRICULUM ────────────────────────────────────────────── -->
  <section class="py-24 px-6 bg-brand-dark">
    <div class="max-w-3xl mx-auto">

      <div class="mb-12">
        <p class="text-brand-red uppercase tracking-widest text-sm font-semibold mb-3">Curriculum</p>
        <h2 class="font-display text-4xl font-bold mb-4">White to Blue Belt</h2>
        <p class="text-white/60 text-lg max-w-2xl">
          The full Pedro Sauer Association Blue Belt curriculum. Click a category to see techniques.
        </p>
      </div>

      <!-- Jiu Jitsu Core Movement -->
      <div class="mb-10 border border-white/10 rounded-2xl p-6 bg-brand-gray">
        <p class="text-brand-red uppercase tracking-widest text-xs font-semibold mb-4">Jiu Jitsu Core Movement</p>
        <ul class="grid sm:grid-cols-2 gap-x-6 gap-y-2.5">
          {coreMovement.map((t: Technique) => {
            const isLinked = typeof t === 'object';
            const title = isLinked ? t.title : t;
            const videoId = isLinked ? t.videoId : null;
            return (
              <li class="flex items-start gap-2">
                <span class="text-brand-red shrink-0 mt-0.5 text-xs">▸</span>
                {isLinked ? (
                  <button
                    class="video-trigger text-white/70 text-sm hover:text-brand-red transition flex items-center gap-1.5 text-left"
                    data-video-id={videoId}
                    data-video-title={title}
                  >
                    {title}
                    <span class="text-brand-red text-xs opacity-70">▶</span>
                  </button>
                ) : (
                  <span class="text-white/70 text-sm">{title}</span>
                )}
              </li>
            );
          })}
        </ul>
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        {curriculum.map((cat, i) => (
          <div class="cat-item border border-white/10 rounded-2xl overflow-hidden self-start">
            <button
              class="cat-btn w-full flex items-center justify-between px-5 py-4 text-left bg-brand-gray hover:bg-white/5 transition"
              data-index={i}
            >
              <span class="font-semibold text-white text-sm">{cat.category}</span>
              <span class="cat-chevron text-brand-red text-xs transition-transform duration-300 ml-4 shrink-0">↓</span>
            </button>
            <div class="cat-panel hidden px-5 pb-5 bg-brand-gray border-t border-white/10" data-cat-panel={i}>
              <ul class="space-y-2 pt-4">
                {cat.techniques.map((t: Technique) => {
                  const isLinked = typeof t === 'object';
                  const title = isLinked ? t.title : t;
                  const videoId = isLinked ? t.videoId : null;
                  return (
                    <li class="flex items-start gap-3">
                      <span class="text-brand-red shrink-0 mt-0.5 text-xs">▸</span>
                      {isLinked ? (
                        <button
                          class="video-trigger text-white/70 text-sm hover:text-brand-red transition flex items-center gap-1.5 text-left"
                          data-video-id={videoId}
                          data-video-title={title}
                        >
                          {title}
                          <span class="text-brand-red text-xs opacity-70">▶</span>
                        </button>
                      ) : (
                        <span class="text-white/70 text-sm">{title}</span>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <script>
    // Category-level accordion — each category toggles independently
    document.querySelectorAll('.cat-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx     = (btn as HTMLElement).dataset.index!;
        const panel   = document.querySelector(`[data-cat-panel="${idx}"]`) as HTMLElement;
        const chevron = btn.querySelector('.cat-chevron') as HTMLElement;
        const isOpen  = !panel.classList.contains('hidden');
        panel.classList.toggle('hidden', isOpen);
        chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
      });
    });

    // ── Video modal ──────────────────────────────────────────────
    const modal       = document.getElementById('video-modal') as HTMLElement;
    const modalIframe = document.getElementById('modal-iframe') as HTMLIFrameElement;
    const modalTitle  = document.getElementById('modal-title') as HTMLElement;

    function openModal(videoId: string, title: string) {
      modalIframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
      modalTitle.textContent = title;
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      modalIframe.src = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.video-trigger').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        openModal(el.dataset.videoId!, el.dataset.videoTitle!);
      });
    });

    // Close on backdrop click
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // Close on ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    // Close button
    document.getElementById('modal-close')?.addEventListener('click', closeModal);
  </script>

  <!-- ── VIDEO MODAL ───────────────────────────────────────────── -->
  <div
    id="video-modal"
    class="hidden fixed inset-0 z-50 flex items-center justify-center px-4"
    style="background:rgba(0,0,0,0.85);"
  >
    <div class="relative w-full max-w-3xl">
      <!-- Title + close row -->
      <div class="flex items-center justify-between mb-3">
        <p id="modal-title" class="text-white font-semibold text-sm truncate pr-4"></p>
        <button
          id="modal-close"
          class="shrink-0 text-white/50 hover:text-white text-2xl leading-none transition"
          aria-label="Close"
        >✕</button>
      </div>
      <!-- Embed -->
      <div class="relative w-full rounded-2xl overflow-hidden bg-black" style="aspect-ratio:16/9;">
        <iframe
          id="modal-iframe"
          src=""
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="absolute inset-0 w-full h-full"
        ></iframe>
      </div>
    </div>
  </div>

  <div style="height:50px;background:linear-gradient(to bottom,#0d0d0d,#1a1a1a);"></div>

  <!-- ─── CTA ─────────────────────────────────────────────────── -->
  <section class="py-20 px-6 bg-brand-gray text-center">
    <p class="text-brand-red uppercase tracking-widest text-sm font-semibold mb-3">Come Train With Us</p>
    <h2 class="font-display text-4xl font-bold mb-4">See It Live on the Mat</h2>
    <p class="text-white/60 text-lg mb-10 max-w-lg mx-auto">
      Videos are great — but nothing beats learning in person. Your first 10 days are free, unlimited classes included.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="https://app.clubworx.com/websites/rob-williams-bjj/waivers/waiver-without-payment-auth/signed_waivers/new" target="_blank" rel="noopener" class="bg-brand-red hover:bg-red-700 text-white font-bold text-lg px-10 py-4 rounded transition inline-block">
        Book a Free Trial
      </a>
      <a href="/timetable" class="border border-white/30 hover:border-white text-white font-semibold text-lg px-10 py-4 rounded transition inline-block">
        View Timetable
      </a>
    </div>
  </section>

  <div style="height:50px;background:linear-gradient(to bottom,#1a1a1a,#0d0d0d);"></div>

  <!-- ─── FOOTER ────────────────────────────────────────────────── -->
  <footer class="bg-brand-dark py-14 px-6">
    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-10">
      <div>
        <p class="font-display text-xl font-bold mb-3">ROB WILLIAMS <span class="text-brand-red">BJJ</span></p>
        <p class="text-white/50 text-sm leading-relaxed">
          Authentic Gracie Jiu Jitsu self-defence academy.<br />
          South Brisbane · Meadowbrook QLD
        </p>
      </div>
      <div>
        <p class="font-semibold text-white/80 mb-4 text-sm uppercase tracking-wide">Contact</p>
        <ul class="space-y-3 text-white/60 text-sm">
          <li><a href="tel:0421729868" class="hover:text-white transition">📞 0421 729 868</a></li>
          <li><a href="mailto:robwilliamsgz@gmail.com" class="hover:text-white transition">✉️ robwilliamsgz@gmail.com</a></li>
          <li>
            <a href="https://maps.google.com/?q=3/45+Nealdon+Dr+Meadowbrook+QLD+4131" target="_blank" rel="noopener" class="hover:text-white transition">
              📍 3/45 Nealdon Dr, Meadowbrook QLD 4131
            </a>
          </li>
        </ul>
      </div>
      <div>
        <p class="font-semibold text-white/80 mb-4 text-sm uppercase tracking-wide">Quick Links</p>
        <ul class="space-y-2 text-white/60 text-sm">
          <li><a href="/about" class="hover:text-white transition">About</a></li>
          <li><a href="/programs" class="hover:text-white transition">Programs</a></li>
          <li><a href="/timetable" class="hover:text-white transition">Timetable &amp; Pricing</a></li>
          <li><a href="/team" class="hover:text-white transition">Our Team</a></li>
          <li><a href="/contact" class="hover:text-white transition">Contact</a></li>
          <li><a href="/faq" class="hover:text-white transition">FAQ</a></li>
          <li><a href="/resources" class="hover:text-white transition">Resources</a></li>
          <li><a href="https://app.clubworx.com/websites/rob-williams-bjj/waivers/waiver-without-payment-auth/signed_waivers/new" target="_blank" rel="noopener" class="hover:text-white transition">Free Trial</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-5xl mx-auto mt-10 pt-6 border-t border-white/10 text-center text-white/30 text-xs">
      © {new Date().getFullYear()} Rob Williams BJJ. All rights reserved.
    </div>
