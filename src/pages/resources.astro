import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

// Fetch latest video server-side at build time (no CORS issues)
let latestVideoId    = 'ArStX4WJoxI';
let latestVideoTitle = 'Saturdays!!!! #bjj';

try {
  const channelId = 'UCdjnapRr2XcGAiMoyZCPvmw';
  const res = await fetch(`https://www.youtube.com/feeds/videos.xml?channel_id=${channelId}`);
  if (res.ok) {
    const xml = await res.text();
    const idMatch    = xml.match(/<yt:videoId>([^<]+)<\/yt:videoId>/);
    const titleMatch = xml.match(/<title>(?!Rob Williams BJJ)([^<]+)<\/title>/);
    if (idMatch?.[1])    latestVideoId    = idMatch[1];
    if (titleMatch?.[1]) latestVideoTitle = titleMatch[1];
  }
} catch {
  // Keep fallback values
}

