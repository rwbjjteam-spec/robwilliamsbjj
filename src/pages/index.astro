        { src: '/Gallery/Legends.Rob.Rickson.Gracie.png', alt: 'Rob with Rickson Gracie' },
        { src: '/Gallery/Adults.rolling.png',             alt: 'Adults rolling' },
        { src: '/Gallery/Kids.focus.png',                 alt: 'Kids focused' },
        { src: '/Gallery/Ladies.standing.png',            alt: 'Ladies class' },
        { src: '/Gallery/Adults.saturday.png',            alt: 'Saturday class' },
        { src: '/Gallery/Kids.backmount.png',             alt: 'Kids back mount' },
        { src: '/Gallery/Legends.Rob.McKenzie.png',       alt: 'Rob with McKenzie Dern' },
        { src: '/Gallery/Adults.morningsesh.png',         alt: 'Morning session' },
        { src: '/Gallery/Ladies.stripe.png',              alt: 'Ladies stripe ceremony' },
        { src: '/Gallery/Adults.action.png',              alt: 'Adults training' },
        { src: '/Gallery/Kids.teaching.png',              alt: 'Kids class' },
        { src: '/Gallery/Ladies.jj.png',                  alt: 'Ladies Jiu Jitsu' },
        { src: '/Gallery/Legends.Rob.Rickson.Gracie.png', alt: 'Rob with Rickson Gracie' },
        { src: '/Gallery/Adults.rolling.png',             alt: 'Adults rolling' },
        { src: '/Gallery/Kids.focus.png',                 alt: 'Kids focused' },
        { src: '/Gallery/Ladies.standing.png',            alt: 'Ladies class' },
        { src: '/Gallery/Adults.saturday.png',            alt: 'Saturday class' },
        { src: '/Gallery/Kids.backmount.png',             alt: 'Kids back mount' },
        { src: '/Gallery/Legends.Rob.McKenzie.png',       alt: 'Rob with McKenzie Dern' },
        { src: '/Gallery/Adults.morningsesh.png',         alt: 'Morning session' },
        { src: '/Gallery/Ladies.stripe.png',              alt: 'Ladies stripe ceremony' },
      ].map(({ src, alt }) => (
