      <script>
        // ── Taipans-style CTA switch (coming soon vs real booking buttons) ──
        (function () {
          const now = new Date();
          document.querySelectorAll<HTMLElement>('[id^="mobile-cta-real-"], [id^="desktop-cta-real-"]').forEach(realCta => {
            const comingSoonId = realCta.id.replace('-real-', '-comingsoon-');
            const comingSoon = document.getElementById(comingSoonId);
            const switchDate = realCta.dataset.switch;
            if (!switchDate) return;
            if (now >= new Date(switchDate)) {
              realCta.classList.replace('hidden', 'block');
            } else if (comingSoon) {
              comingSoon.classList.replace('hidden', 'block');
            }
          });
        })();

        // ── Mobile inline expansion ──
        document.querySelectorAll('.mobile-program-group').forEach(group => {
          const btn     = group.querySelector('.mobile-card') as HTMLElement;
          const detail  = group.querySelector('.mobile-detail') as HTMLElement;
          const chevron = group.querySelector('.mobile-chevron') as HTMLElement;
          btn?.addEventListener('click', () => {
            const isOpen = !detail.classList.contains('hidden');
            // Close all others first
            document.querySelectorAll('.mobile-detail').forEach(d => d.classList.add('hidden'));
            document.querySelectorAll('.mobile-card').forEach(b => { b.classList.remove('!border-brand-red', 'rounded-b-none'); });
            document.querySelectorAll('.mobile-chevron').forEach(c => { (c as HTMLElement).style.transform = ''; });
            if (!isOpen) {
              detail.classList.remove('hidden');
              btn.classList.add('!border-brand-red', 'rounded-b-none');
              chevron.style.transform = 'rotate(180deg)';
              detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
          });
        });

        // ── Desktop grid + panel below ──
        const cards  = document.querySelectorAll('.program-card');
        const panels = document.querySelectorAll('.program-detail');
        cards.forEach(card => {
          card.addEventListener('click', () => {
            const id     = (card as HTMLElement).dataset.program;
            const panel  = document.getElementById(`program-${id}`);
            const isOpen = !panel?.classList.contains('hidden');
            panels.forEach(p => p.classList.add('hidden'));
            cards.forEach(c => c.classList.remove('!border-brand-red'));
            if (!isOpen && panel) {
              panel.classList.remove('hidden');
              card.classList.add('!border-brand-red');
              panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
          });
        });
      </script>
