  <style>
    .strip-nav-btn {
      background: rgba(0,0,0,0.55);
      border: 1px solid rgba(255,255,255,0.2);
      color: white;
      border-radius: 50%;
      width: 2.25rem;
      height: 2.25rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s, border-color 0.2s;
    }
    .strip-nav-btn:hover { background: #c41230; border-color: #c41230; }
  </style>

  <script>
    function initStrip(trackId: string, prevId: string, nextId: string) {
      const track = document.getElementById(trackId) as HTMLElement;
      const prev  = document.getElementById(prevId)  as HTMLElement;
      const next  = document.getElementById(nextId)  as HTMLElement;
      if (!track) return;

      let pos      = 0;
      let paused   = false;
      let lastTime = performance.now();
      const jump   = 400;
      const duration = 100000; // ms to scroll half the track

      function half() { return track.scrollWidth / 2; }

      function tick(now: number) {
        const dt = now - lastTime;
        lastTime = now;
        if (!paused) {
          pos += (half() / duration) * dt;
          if (pos >= half()) pos -= half();
        }
        track.style.transform = `translateX(-${pos}px)`;
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);

      track.addEventListener('mouseenter', () => paused = true);
      track.addEventListener('mouseleave', () => paused = false);

      prev?.addEventListener('click', () => {
        pos -= jump;
        if (pos < 0) pos += half();
      });
      next?.addEventListener('click', () => {
        pos += jump;
        if (pos >= half()) pos -= half();
      });
    }

    initStrip('strip-home-track', 'strip-home-prev', 'strip-home-next');
  </script>

