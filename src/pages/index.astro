              <a href="https://app.clubworx.com/websites/rob-williams-bjj/waivers/waiver-without-payment-auth/signed_waivers/new" target="_blank" rel="noopener" class="inline-block bg-brand-red hover:bg-red-700 text-white font-bold px-8 py-3 rounded transition text-sm">
                Book a free trial →
              </a>
            )}
