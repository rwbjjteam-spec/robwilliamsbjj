            </tr>
          </thead>
          <tbody>
            {schedule.map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-[#e8e8e8]' : 'bg-[#dedede]'}>
                <td class="text-black/40 font-mono text-xs px-4 py-3 whitespace-nowrap border-r border-black/10">
