<style>
  .class-cell, .legend-item { transition: opacity 0.15s, box-shadow 0.15s, transform 0.15s; }
  .class-cell.dimmed, .legend-item.dimmed { opacity: 0.25; }
  .class-cell.highlighted { box-shadow: 0 0 0 2px white, 0 0 12px rgba(255,255,255,0.3); transform: scale(1.04); opacity: 1; }
  .legend-item.highlighted { box-shadow: 0 0 0 2px white, 0 0 10px rgba(255,255,255,0.2); transform: scale(1.06); opacity: 1; }
</style>

<script>
  const items = document.querySelectorAll<HTMLElement>('[data-class-type]');
  let lockedType: string | null = null;

  function applyHighlight(type: string | null) {
    items.forEach(el => {
      if (!type) {
        el.classList.remove('highlighted', 'dimmed');
      } else if (el.dataset.classType === type) {
        el.classList.add('highlighted');
        el.classList.remove('dimmed');
      } else {
        el.classList.add('dimmed');
        el.classList.remove('highlighted');
      }
    });
  }

  items.forEach(item => {
    // Hover: only previews when nothing is locked
    item.addEventListener('mouseenter', () => {
      if (!lockedType) applyHighlight(item.dataset.classType ?? null);
    });
    item.addEventListener('mouseleave', () => {
      if (!lockedType) applyHighlight(null);
    });

    // Click / tap: lock or unlock a type
    item.addEventListener('click', () => {
      const type = item.dataset.classType ?? null;
      if (lockedType === type) {
        lockedType = null;
        applyHighlight(null);
      } else {
        lockedType = type;
        applyHighlight(type);
      }
    });
  });

  // Tap outside any item clears the lock
  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('[data-class-type]')) {
      lockedType = null;
      applyHighlight(null);
    }
  });

  // Belt row hover + tap colours
  document.querySelectorAll<HTMLElement>('.belt-row').forEach(row => {
    const c1 = row.dataset.c1!;
    const c2 = row.dataset.c2!;
    row.addEventListener('mouseenter', () => row.style.borderColor = c2);
    row.addEventListener('mouseleave', () => row.style.borderColor = c1);
    row.addEventListener('touchstart', () => row.style.borderColor = c2, { passive: true });
    row.addEventListener('touchend', () => setTimeout(() => row.style.borderColor = c1, 3500), { passive: true });
  });
</script>

</Layout>
