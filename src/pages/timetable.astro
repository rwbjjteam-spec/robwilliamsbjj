          { label: 'Adults Gi',       type: 'adults-gi',   style: 'bg-blue-700/80 border-blue-500 text-white' },
          { label: 'Adults No Gi',    type: 'adults-nogi', style: 'bg-blue-900/80 border-blue-700 text-white' },
          { label: 'Pythons (4–7)',   type: 'pythons',     style: 'bg-yellow-600/80 border-yellow-500 text-white' },
          { label: 'Anacondas (8–12)',type: 'anacondas',   style: 'bg-orange-600/80 border-orange-400 text-white' },
          { label: 'Girls & Women',   type: 'women',       style: 'bg-emerald-700/80 border-emerald-500 text-white' },
