---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

// Each cell: null = empty, or { label, type }
// types: adults-gi | adults-nogi | pythons | anacondas | women
const schedule = [
  {
    time: '8:00am',
    classes: [null, null, null, null, null, { label: 'Adults Gi', type: 'adults-gi' }],
  },
  {
    time: '9:30am',
    classes: [null, null, null, null, null, { label: 'Anacondas', sub: 'Must Book · Trials OK', type: 'anacondas' }],
  },
  {
    time: '10:00am',
    classes: [
      { label: 'Adults No Gi', type: 'adults-nogi' },
      null,
      { label: 'Adults Gi', type: 'adults-gi' },
      null,
      { label: 'Adults No Gi', type: 'adults-nogi' },
      null,
    ],
  },
  {
    time: '5:00pm',
    classes: [
      { label: 'Girls (13y+) & Women', type: 'women' },
      { label: 'Pythons', sub: '30 mins', type: 'pythons' },
      null,
      { label: 'Pythons', sub: '30 mins', type: 'pythons' },
      null,
      null,
    ],
  },
  {
    time: '5:45pm',
    classes: [
      null,
      { label: 'Anacondas', sub: 'Must Book · Trials OK', type: 'anacondas' },
      null,
      { label: 'Anacondas', sub: 'Must Book · No Trials', type: 'anacondas' },
      null,
      null,
    ],
  },
  {
    time: '6:00pm',
    classes: [
      { label: 'Adults No Gi', type: 'adults-nogi' },
      null,
      null,
      null,
      null,
      null,
    ],
  },
  {
    time: '6:30pm',
    classes: [
      null,
      { label: 'Adults Gi', type: 'adults-gi' },
      null,
      { label: 'Adults No Gi', type: 'adults-nogi' },
      null,
      null,
    ],
  },
];

const typeStyles: Record<string, string> = {
  'adults-gi':   'bg-blue-700/80 border-blue-500',
  'adults-nogi': 'bg-blue-900/80 border-blue-700',
  'pythons':     'bg-yellow-600/80 border-yellow-500',
  'anacondas':   'bg-orange-600/80 border-orange-400',
  'women':       'bg-emerald-700/80 border-emerald-500',
};
---

<Layout
